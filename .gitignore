*.swp
.DS_Store
Thumbs.db

# ez-rag local state
**/.ezrag/
**/conversations/
benchmark/_workspace/
benchmark/reports/*.json

# benchmark corpora caches (re-downloaded on demand)
benchmark/corpus/
ez-rag-test/
my-rag/
# Test RAGs the user/devs build locally — regeneratable with
# bench/fetch_test_corpus.py and shouldn't go into git.
test-rags/
test_rags/

# Benchmark RAW results — the harness scripts under bench/ are committed,
# the data they produce is not.
bench/results*.json
bench/*.log

# Claude Code session state (and any other agent breadcrumbs) — local to
# whoever ran the agent.
.claude/

# logs
*.log

# Hugging Face / ONNX caches if symlinked locally
.fastembed_cache/
fastembed_cache/

# OS-level cache files
.DS_Store
desktop.ini

# Bulk debug screenshots — keep only the curated ones in docs/screenshots/
_screenshots/

# Bench result bundles — large binary outputs, regenerable on demand.
bench-results/

# Bench workspaces (vectors + sqlite) and historical run bundles.
# We commit one showcase bundle for GitHub viewers (see exception
# below), everything else is local-only.
bench/_ohio-workspaces/
bench/reports/dnd5e-quality-*
bench/reports/multimodel-*
bench/reports/ohio-20260503-184645/
# But DO commit the v2 Ohio showcase (~9.6 MB, JSON + HTML report)
!bench/reports/ohio-20260503-211733/
!bench/reports/ohio-20260503-211733/**

# Sample-data downloads — ~100 MB of public-domain government docs.
# The README + curation.json + fetch.py are committed; the fetched
# bytes are not. Re-fetchable via `python sample_data/fetch.py`.
sample_data/fetched/
sample_data/manifest.json
